<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@drawable/gradient_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="32dp"
        android:gravity="center_horizontal">

        <!-- Logo -->
        <ImageView
            android:layout_width="90dp"
            android:layout_height="90dp"
            android:src="@drawable/ic_prosync_logo"
            android:layout_marginTop="60dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ProSync"
            android:textSize="38sp"
            android:textStyle="bold"
            android:textColor="@color/gold"
            android:layout_marginTop="12dp"
            android:letterSpacing="0.05"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Gestión de proyectos colaborativa"
            android:textSize="13sp"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="40dp"
            android:layout_marginTop="4dp"/>

        <!-- Email -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Correo electrónico"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_marginBottom="16dp"
            app:boxStrokeColor="@color/primary_light"
            app:hintTextColor="@color/text_secondary"
            app:boxBackgroundColor="@color/surface">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etEmail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textEmailAddress"
                android:textColor="@color/text_primary"
                android:imeOptions="actionNext"/>
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Password -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Contraseña"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            app:passwordToggleEnabled="true"
            app:boxStrokeColor="@color/primary_light"
            app:hintTextColor="@color/text_secondary"
            app:boxBackgroundColor="@color/surface"
            android:layout_marginBottom="24dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etPassword"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textPassword"
                android:textColor="@color/text_primary"
                android:imeOptions="actionDone"/>
        </com.google.android.material.textfield.TextInputLayout>

        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:indeterminateTint="@color/gold"
            android:visibility="gone"
            android:layout_marginBottom="8dp"/>

        <!-- Botón login -->
        <Button
            android:id="@+id/btnLogin"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="INICIAR SESIÓN"
            android:textColor="@color/primary_darker"
            android:textStyle="bold"
            android:textSize="15sp"
            android:background="@drawable/gold_button_bg"
            android:stateListAnimator="@null"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="— o continúa con —"
            android:gravity="center"
            android:textColor="@color/text_hint"
            android:textSize="13sp"
            android:layout_marginVertical="16dp"/>

        <!-- Botón Google -->
        <Button
            android:id="@+id/btnGoogleLogin"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Continuar con Google"
            android:textColor="@color/gold"
            android:textStyle="bold"
            android:background="@drawable/outline_gold"
            android:drawableStart="@drawable/ic_google"
            android:drawablePadding="8dp"
            android:stateListAnimator="@null"/>

        <TextView
            android:id="@+id/tvGoRegister"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="¿No tienes cuenta? Regístrate"
            android:textColor="@color/gold_light"
            android:padding="16dp"
            android:layout_marginTop="8dp"/>

    </LinearLayout>
</ScrollView>
